{
    "name": "ecotone/laravel",
    "minimum-stability": "dev",
    "homepage": "https://docs.ecotone.tech/",
    "forum": "https://discord.gg/GwM2BSuXeg",
    "prefer-stable": true,
    "license": [
        "Apache-2.0",
        "proprietary"
    ],
    "type": "library",
    "authors": [
        {
            "name": "Dariusz Gafka",
            "email": "support@simplycodedsoftware.com"
        }
    ],
    "keywords": [
        "ddd",
        "cqrs",
        "laravel",
        "laravel-queue",
        "event-sourcing",
        "sagas",
        "durable-workflows",
        "workflow",
        "outbox",
        "ecotone",
        "messaging",
        "eip"
    ],
    "description": "Ecotone for Laravel \u2014 CQRS, Event Sourcing, Sagas, Durable Workflows, and Outbox on top of Laravel Queue, via PHP attributes.",
    "repositories": [
        {
            "type": "path",
            "url": "../*",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Ecotone\\Laravel\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\Ecotone\\Laravel\\": "tests",
            "App\\MultiTenant\\": "tests/MultiTenant/app",
            "App\\Licence\\Laravel\\": "tests/Licence/app"
        }
    },
    "require": {
        "ecotone/ecotone": "~1.313.2",
        "laravel/framework": "^9.5.2|^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "guzzlehttp/psr7": "^2.0",
        "phpstan/phpstan": "^1.8",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0",
        "symfony/expression-language": "^6.4|^7.0|^8.0",
        "nesbot/carbon": "^2.71|^3.0",
        "moneyphp/money": "^4.1.0",
        "ecotone/dbal": "~1.313.2",
        "timacdonald/log-fake": "^2.0"
    },
    "extra": {
        "laravel": {
            "providers": [
                "Ecotone\\Laravel\\EcotoneProvider"
            ]
        },
        "branch-alias": {
            "dev-main": "1.313.2-dev"
        },
        "ecotone": {
            "repository": "laravel"
        },
        "license-info": {
            "Apache-2.0": {
                "name": "Apache License 2.0",
                "url": "https://github.com/ecotoneframework/ecotone-dev/blob/main/LICENSE",
                "description": "Allows to use non Enterprise features of Ecotone. For more information please write to support@simplycodedsoftware.com"
            },
            "proprietary": {
                "name": "Enterprise License",
                "description": "Allows to use Enterprise features of Ecotone. For more information please write to support@simplycodedsoftware.com"
            }
        },
        "release-time": "2026-05-22 17:45:28"
    },
    "scripts": {
        "tests:phpstan": "vendor/bin/phpstan",
        "tests:phpunit": [
            "vendor/bin/phpunit --no-coverage"
        ],
        "tests:ci": [
            "@tests:phpstan",
            "@tests:phpunit"
        ]
    }
}