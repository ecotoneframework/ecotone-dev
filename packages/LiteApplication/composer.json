{
    "name": "ecotone/lite-application",
    "minimum-stability": "dev",
    "homepage": "https://docs.ecotone.tech/",
    "forum": "https://discord.gg/GwM2BSuXeg",
    "prefer-stable": true,
    "license": [
        "Apache-2.0",
        "proprietary"
    ],
    "type": "library",
    "authors": [
        {
            "name": "Dariusz Gafka",
            "email": "support@simplycodedsoftware.com"
        }
    ],
    "keywords": [
        "ecotone",
        "ecotone-lite",
        "psr-11",
        "ddd",
        "cqrs",
        "event-sourcing",
        "sagas",
        "durable-workflows",
        "workflow",
        "framework-agnostic"
    ],
    "description": "Ecotone Lite \u2014 framework-agnostic bootstrap for PSR-11 applications with CQRS, Event Sourcing, Sagas, Durable Workflows, and Outbox.",
    "repositories": [
        {
            "type": "path",
            "url": "../*",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "Ecotone\\Lite\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Test\\Ecotone\\Lite\\": "tests"
        }
    },
    "require": {
        "ecotone/ecotone": "~1.313.2",
        "ecotone/jms-converter": "~1.313.2",
        "php-di/php-di": "^7.0.5"
    },
    "require-dev": {
        "phpunit/phpunit": "^10.5|^11.0",
        "guzzlehttp/psr7": "^2.0",
        "phpstan/phpstan": "^1.8",
        "orchestra/testbench": "^8.0|^9.0|^10.0|^11.0"
    },
    "extra": {
        "branch-alias": {
            "dev-main": "1.313.2-dev"
        },
        "ecotone": {
            "repository": "lite-application"
        },
        "license-info": {
            "Apache-2.0": {
                "name": "Apache License 2.0",
                "url": "https://github.com/ecotoneframework/ecotone-dev/blob/main/LICENSE",
                "description": "Allows to use non Enterprise features of Ecotone. For more information please write to support@simplycodedsoftware.com"
            },
            "proprietary": {
                "name": "Enterprise License",
                "description": "Allows to use Enterprise features of Ecotone. For more information please write to support@simplycodedsoftware.com"
            }
        },
        "release-time": "2026-05-22 17:45:28"
    },
    "scripts": {
        "tests:phpstan": "vendor/bin/phpstan",
        "tests:phpunit": [
            "vendor/bin/phpunit --no-coverage"
        ],
        "tests:ci": [
            "@tests:phpstan",
            "@tests:phpunit"
        ]
    }
}