{
    "name": "ecotone/quickstart",
    "license": "MIT",
    "authors": [
        {
            "name": "Dariusz Gafka",
            "email": "support@simplycodedsoftware.com"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\Microservices\\BackofficeService\\": "BackofficeService/src",
            "App\\Microservices\\CustomerService\\": "CustomerService/src"
        }
    },
    "require": {
        "ecotone/lite-amqp-starter": "^1.0.1",
        "ecotone/lite-event-sourcing-starter": "^1.0",
        "ramsey/uuid": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6|^10.5|^11.0"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
