{
    "name": "ecotone/quickstart",
    "license": "MIT",
    "authors": [
        {
            "name": "Dariusz Gafka",
            "email": "dgafka.mail@gmail.com"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../../../../packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\MultiTenant\\": "src"
        }
    },
    "require": {
        "doctrine/orm": "^3.3",
        "doctrine/persistence": "^4.0",
        "ecotone/lite-dbal-starter": "^1.0.1"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6|^10.5|^11.0"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
