{
    "name": "ecotone/quickstart",
    "license": "MIT",
    "authors": [
        {
            "name": "Dariusz Gafka",
            "email": "dgafka.mail@gmail.com"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../../packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\ReactiveSystem\\": "src"
        }
    },
    "require": {
        "ecotone/lite-dbal-starter": "^1.0.1",
        "moneyphp/money": "^4.1.0",
        "symfony/http-foundation": "^6.4|^7.0|^8.0",
        "ramsey/uuid": "^4.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^9.6|^10.5|^11.0"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
