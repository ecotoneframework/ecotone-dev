{
    "name": "ecotone/quickstart-tempest-multitenant",
    "license": "MIT",
    "authors": [
        {
            "name": "Dariusz Gafka",
            "email": "dgafka.mail@gmail.com"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../../../../packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\": "app"
        }
    },
    "require": {
        "ecotone/tempest": "*",
        "ecotone/dbal": "*",
        "ecotone/jms-converter": "*",
        "tempest/framework": "^3.11",
        "ramsey/uuid": "^4.0",
        "symfony/expression-language": "^6.4|^7.0|^8.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11.0"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "tempest/highlight": true
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
