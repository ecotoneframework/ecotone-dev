{
    "name": "ecotone/quickstart",
    "license": "MIT",
    "authors": [
        {
            "name": "Dariusz Gafka",
            "email": "dgafka.mail@gmail.com"
        }
    ],
    "repositories": [
        {
            "type": "path",
            "url": "../../../packages/*",
            "options": {
                "symlink": true
            }
        }
    ],
    "autoload": {
        "psr-4": {
            "App\\Workflow\\Saga\\": "src"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\App\\Workflow\\Saga\\": "tests"
        }
    },
    "require": {
        "ecotone/lite-dbal-starter": "^1.0.1",
        "intervention/image": "^3.5.1",
        "moneyphp/money": "^4.1.0",
        "webmozart/assert": "^1.11",
        "ramsey/uuid": "^4.0"
    },
    "require-dev": {
        "doctrine/orm": "^2.11|^3.0",
        "phpunit/phpunit": "^9.6|^10.5|^11.0"
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
